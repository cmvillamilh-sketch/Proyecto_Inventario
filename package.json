{
  "name": "mante-stock",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "docker:up": "docker-compose up -d postgres",
    "docker:down": "docker-compose down",
    "check:node": "node -v"
  },
  "engines": {
    "node": "20.x"
  }
}
