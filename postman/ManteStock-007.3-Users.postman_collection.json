{
  "info": {
    "name": "ManteStock 007.3 - Users (RolesGuard + CRUD)",
    "description": "Prueba guiada del checkpoint 007.3. Ejecutar los requests EN ORDEN (1 a 13), a mano o con Collection Runner. Cada request incluye un test automático que dice PASS/FAIL en la pestaña 'Test Results'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "adminToken", "value": "" },
    { "key": "adminId", "value": "" },
    { "key": "tecnicoToken", "value": "" },
    { "key": "testUserId", "value": "" },
    { "key": "testUsername", "value": "" }
  ],
  "item": [
    {
      "name": "1. Login admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"Admin123!\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created (Nest devuelve 201 en POST por defecto, no hay @HttpCode(200) en login)', () => pm.response.to.have.status(201));",
          "const json = pm.response.json();",
          "pm.collectionVariables.set('adminToken', json.accessToken);",
          "pm.collectionVariables.set('adminId', json.user.id);"
        ]}
      }]
    },
    {
      "name": "2. Login tecnico1",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"tecnico1\",\"password\":\"Tecnico123!\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created', () => pm.response.to.have.status(201));",
          "const json = pm.response.json();",
          "pm.collectionVariables.set('tecnicoToken', json.accessToken);"
        ]}
      }]
    },
    {
      "name": "3. GET /users como tecnico1 -> esperar 403",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{tecnicoToken}}" }],
        "url": "{{baseUrl}}/users"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('403 Forbidden (no 401)', () => pm.response.to.have.status(403));"
        ]}
      }]
    },
    {
      "name": "4. GET /users como admin -> esperar 200, sin passwordHash",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/users"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK', () => pm.response.to.have.status(200));",
          "const json = pm.response.json();",
          "pm.test('respuesta es un array', () => pm.expect(Array.isArray(json)).to.be.true);",
          "pm.test('ningun usuario expone passwordHash', () => {",
          "  json.forEach(u => pm.expect(u).to.not.have.property('passwordHash'));",
          "});"
        ]}
      }]
    },
    {
      "name": "5. POST /users con password debil -> esperar 400",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"username\":\"test_weakpass\",\"password\":\"abc123\",\"role\":\"TECNICO\"}" },
        "url": "{{baseUrl}}/users"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('400 Bad Request', () => pm.response.to.have.status(400));"
        ]}
      }]
    },
    {
      "name": "6. DELETE /users/:id (admin sobre si mismo) -> esperar 400",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/users/{{adminId}}"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('400 Bad Request (no puede autodesactivarse)', () => pm.response.to.have.status(400));"
        ]}
      }]
    },
    {
      "name": "7. POST /users - crear usuario de prueba",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"username\":\"{{testUsername}}\",\"password\":\"ClaveVieja123\",\"role\":\"TECNICO\"}" },
        "url": "{{baseUrl}}/users"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": { "exec": [
            "pm.collectionVariables.set('testUsername', 'test_user_' + Date.now());"
          ]}
        },
        {
          "listen": "test",
          "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.collectionVariables.set('testUserId', json.id);"
          ]}
        }
      ]
    },
    {
      "name": "8. Login test_user con clave original -> esperar 201",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"{{testUsername}}\",\"password\":\"ClaveVieja123\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created', () => pm.response.to.have.status(201));"
        ]}
      }]
    },
    {
      "name": "9. PATCH /users/:id/reset-password (admin resetea al usuario de prueba)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"newPassword\":\"ClaveNueva456\"}" },
        "url": "{{baseUrl}}/users/{{testUserId}}/reset-password"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK', () => pm.response.to.have.status(200));"
        ]}
      }]
    },
    {
      "name": "10. Login test_user con clave vieja tras reset -> esperar 401",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"{{testUsername}}\",\"password\":\"ClaveVieja123\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('401 Unauthorized (la clave vieja ya no sirve)', () => pm.response.to.have.status(401));"
        ]}
      }]
    },
    {
      "name": "11. Login test_user con clave nueva -> esperar 201",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"{{testUsername}}\",\"password\":\"ClaveNueva456\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created (la clave nueva funciona)', () => pm.response.to.have.status(201));"
        ]}
      }]
    },
    {
      "name": "12. DELETE /users/:id (soft-delete del usuario de prueba) -> esperar 200",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/users/{{testUserId}}"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK', () => pm.response.to.have.status(200));"
        ]}
      }]
    },
    {
      "name": "13. GET /users/:id tras soft-delete -> sigue existiendo, isActive:false",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/users/{{testUserId}}"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK (el usuario NO se borro fisicamente)', () => pm.response.to.have.status(200));",
          "const json = pm.response.json();",
          "pm.test('isActive es false', () => pm.expect(json.isActive).to.equal(false));"
        ]}
      }]
    }
  ]
}
