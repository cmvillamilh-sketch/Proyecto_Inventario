{
  "info": {
    "name": "ManteStock 007.4 - createdBy en Material e InventoryMovement",
    "description": "Corre los requests EN ORDEN (1 a 6). Revisa la pestana 'Test Results' de cada uno.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "adminToken", "value": "" },
    { "key": "tecnicoToken", "value": "" },
    { "key": "testMaterialCode", "value": "" },
    { "key": "testMaterialId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Login admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"Admin123!\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created', () => pm.response.to.have.status(201));",
          "pm.collectionVariables.set('adminToken', pm.response.json().accessToken);"
        ]}
      }]
    },
    {
      "name": "2. Login tecnico1",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"tecnico1\",\"password\":\"Tecnico123!\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created', () => pm.response.to.have.status(201));",
          "pm.collectionVariables.set('tecnicoToken', pm.response.json().accessToken);"
        ]}
      }]
    },
    {
      "name": "3. POST /materials como admin -> createdBy debe ser 'admin'",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"code\":\"{{testMaterialCode}}\",\"description\":\"Material de prueba 007.4\",\"category\":\"PRUEBA\",\"unitOfMeasure\":\"unidad\",\"minimumStock\":1}" },
        "url": "{{baseUrl}}/materials"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": { "exec": [
            "pm.collectionVariables.set('testMaterialCode', 'TEST-' + Date.now());"
          ]}
        },
        {
          "listen": "test",
          "script": { "exec": [
            "pm.test('201 Created', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test(\"createdBy es 'admin'\", () => pm.expect(json.createdBy).to.equal('admin'));",
            "pm.collectionVariables.set('testMaterialId', json.id);"
          ]}
        }
      ]
    },
    {
      "name": "4. POST /inventory-movements como tecnico1 -> createdBy debe ser 'tecnico1'",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{tecnicoToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\"materialId\":\"{{testMaterialId}}\",\"type\":\"ENTRY\",\"quantity\":5,\"reason\":\"Prueba 007.4\"}" },
        "url": "{{baseUrl}}/inventory-movements"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created', () => pm.response.to.have.status(201));",
          "const json = pm.response.json();",
          "pm.test(\"createdBy es 'tecnico1'\", () => pm.expect(json.createdBy).to.equal('tecnico1'));"
        ]}
      }]
    },
    {
      "name": "5. GET /materials/:id del material nuevo -> confirma createdBy persistido",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/materials/{{testMaterialId}}"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK', () => pm.response.to.have.status(200));",
          "const json = pm.response.json();",
          "pm.test(\"createdBy sigue siendo 'admin'\", () => pm.expect(json.createdBy).to.equal('admin'));"
        ]}
      }]
    },
    {
      "name": "6. GET /materials completo -> materiales viejos deben tener createdBy null (informativo)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/materials"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK', () => pm.response.to.have.status(200));",
          "const json = pm.response.json();",
          "const sinCreatedBy = json.filter(m => m.createdBy === null).length;",
          "const conCreatedBy = json.filter(m => m.createdBy !== null).length;",
          "console.log(`Materiales con createdBy null (viejos): ${sinCreatedBy}`);",
          "console.log(`Materiales con createdBy asignado (nuevos): ${conCreatedBy}`);",
          "pm.test('la respuesta no se rompe por los registros viejos con createdBy null', () => pm.expect(json.length).to.be.greaterThan(0));"
        ]}
      }]
    }
  ]
}
