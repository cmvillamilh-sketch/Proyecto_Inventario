{
  "info": {
    "name": "ManteStock 009 - Dashboard y busqueda de materiales",
    "description": "Corre los requests EN ORDEN. Revisa la pestana 'Test Results' de cada uno.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "adminToken", "value": "" }
  ],
  "item": [
    {
      "name": "1. Login admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"Admin123!\"}" },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('201 Created', () => pm.response.to.have.status(201));",
          "pm.collectionVariables.set('adminToken', pm.response.json().accessToken);"
        ]}
      }]
    },
    {
      "name": "2. GET /materials/summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/materials/summary"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK (no lo confunde con un :id)', () => pm.response.to.have.status(200));",
          "const json = pm.response.json();",
          "pm.test('trae las 4 llaves esperadas', () => {",
          "  pm.expect(json).to.have.property('totalMaterials');",
          "  pm.expect(json).to.have.property('totalStockUnits');",
          "  pm.expect(json).to.have.property('lowStockCount');",
          "  pm.expect(json).to.have.property('lowStockMaterials');",
          "});",
          "pm.test('lowStockCount coincide con el largo del array', () => pm.expect(json.lowStockCount).to.equal(json.lowStockMaterials.length));",
          "pm.test('todos los de lowStockMaterials cumplen currentStock <= minimumStock', () => {",
          "  json.lowStockMaterials.forEach(m => pm.expect(m.currentStock).to.be.at.most(m.minimumStock));",
          "});"
        ]}
      }]
    },
    {
      "name": "3. GET /materials?search=mat (parcial, sin distinguir mayusculas)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/materials?search=mat"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK', () => pm.response.to.have.status(200));",
          "const json = pm.response.json();",
          "pm.test('todos los resultados contienen \"mat\" en code o description', () => {",
          "  json.forEach(m => {",
          "    const enCode = m.code.toLowerCase().includes('mat');",
          "    const enDescripcion = m.description.toLowerCase().includes('mat');",
          "    pm.expect(enCode || enDescripcion).to.be.true;",
          "  });",
          "});"
        ]}
      }]
    },
    {
      "name": "4. GET /materials?search=xyz-no-deberia-existir",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/materials?search=xyz-no-deberia-existir"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('200 OK (no rompe con 0 resultados)', () => pm.response.to.have.status(200));",
          "pm.test('devuelve array vacio', () => pm.expect(pm.response.json()).to.be.an('array').that.is.empty);"
        ]}
      }]
    }
  ]
}
